    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet">
    
    <style>
        :root {
            /* Paper Theme Colors */
            --paper-bg: #F5F3ED;
            --ink-black: #1A1A1A;
            --ink-light: #5A5A5A;
            --border-color: #DCD8C8;
        }
        
        body {
            background-color: var(--paper-bg);
            color: var(--ink-black);
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            /* Subtle paper texture using noise overlay */
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.03'/%3E%3C/svg%3E");
        }

        .font-serif { font-family: 'Playfair Display', serif; }
        .text-ink { color: var(--ink-black); }
        .text-ink-light { color: var(--ink-light); }
        .border-paper { border-color: var(--border-color); }

        /* Minimalist scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #dcd8c8; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #a8a495; }
        
        /* Single Page Sections */
        .page-section {
            padding-top: 120px; /* Space for fixed navbar */
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        /* Nav link active state for ScrollSpy */
        .nav-link { position: relative; }
        .nav-link::after {
            content: '';
            position: absolute;
            width: 0;
            height: 1px;
            bottom: -4px;
            left: 0;
            background-color: var(--ink-black);
            transition: width 0.3s ease;
        }
        .nav-link:hover::after, .nav-link.active-nav::after {
            width: 100%;
        }
        .nav-link.active-nav {
            color: var(--ink-black);
        }

        /* Map Pulse Animations */
        @keyframes pulse-ring-light {
            0% { transform: scale(0.8); opacity: 0.6; }
            100% { transform: scale(2.5); opacity: 0; }
        }
        .map-dot { position: relative; transform-origin: center; }
        .pulse-circle-light {
            animation: pulse-ring-light 2s cubic-bezier(0.215, 0.61, 0.355, 1) infinite;
        }
        .pulse-delay-1 { animation-delay: 0.5s; }
        .pulse-delay-2 { animation-delay: 1s; }

        /* Chatbot Animations */
        .chatbot-window {
            transform-origin: bottom right;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .chatbot-hidden {
            opacity: 0;
            transform: scale(0.9) translateY(20px);
            pointer-events: none;
        }
        .chatbot-visible {
            opacity: 1;
            transform: scale(1) translateY(0);
            pointer-events: auto;
        }
    </style>
</head>
